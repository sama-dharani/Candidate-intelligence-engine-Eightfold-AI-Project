{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CandidateProfile",
  "type": "object",
  "properties": {
    "full_name": { "type": "string" },
    "emails": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "phones": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "skills": {
      "type": "array",
      "items": { "type": "string" }
    },
    "skill_analysis": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "domain": { "type": "string" },
          "proficiency": { "type": "integer", "minimum": 1, "maximum": 5 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "reasons": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["domain", "proficiency", "confidence", "reasons"]
      }
    },
    "experience": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "company": { "type": "string" },
          "title": { "type": "string" },
          "start_date": { "type": "string" },
          "end_date": { "type": "string" },
          "description": { "type": "string" }
        },
        "required": ["company", "title"]
      }
    },
    "education": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "institution": { "type": "string" },
          "degree": { "type": "string" },
          "start_date": { "type": "string" },
          "end_date": { "type": "string" }
        },
        "required": ["institution"]
      }
    },
    "projects": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "technologies": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["name"]
      }
    },
    "certifications": {
      "type": "array",
      "items": { "type": "string" }
    },
    "location": { "type": "string" },
    "github": { "type": "string" },
    "linkedin": { "type": "string" },
    "confidence": {
      "type": "object",
      "properties": {
        "score": { "type": "number", "minimum": 0, "maximum": 1 },
        "reasons": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["score", "reasons"]
    },
    "provenance": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "source_index": { "type": "integer" },
          "source_type": { "type": "string" },
          "fields_contributed": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "timeline": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "year": { "type": "integer" },
          "title": { "type": "string" },
          "company": { "type": "string" },
          "type": { "type": "string", "enum": ["education", "work"] }
        },
        "required": ["year", "title", "company", "type"]
      }
    },
    "gap_detection": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "start_year": { "type": "integer" },
          "end_year": { "type": "integer" },
          "duration_years": { "type": "integer" },
          "description": { "type": "string" }
        },
        "required": ["start_year", "end_year", "duration_years", "description"]
      }
    },
    "recommendations": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": ["full_name"],
  "additionalProperties": true
}
